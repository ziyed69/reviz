# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ID du prix récurrent (price_xxx) — pas l'ID produit (prod_xxx)
# Produit Reviz Premium → Tarifs → cliquer le prix 5 €/mois → copier l'ID
STRIPE_PRICE_ID=price_...

# Secret pour quotas anti-spam (génère une chaîne aléatoire 32+ caractères)
QUOTA_SECRET=change-moi-en-une-longue-chaine-secrete

# OpenAI — chat PDF + résumés/plans IA (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Stripe — paiement Premium 5 €/mois
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
